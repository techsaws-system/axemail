generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  NOT_ACTIVE
}

enum SenderType {
  GMAIL
  DOMAIN
  MASK
}

enum SenderAccountStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SenderHealthStatus {
  ACTIVE
  BURNED
  BANNED
  NOT_WORKING
}

enum CampaignStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum RecipientStatus {
  QUEUED
  SENT
  FAILED
  BOUNCED
  DELIVERED
  OPENED
  CLICKED
}

model User {
  id               String               @id @default(cuid())
  firstName        String
  lastName         String
  pseudoName       String
  email            String               @unique
  passwordHash     String
  role             Role
  status           UserStatus           @default(ACTIVE)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  allocations      UserSenderAllocation[]
  createdCampaigns Campaign[]           @relation("CampaignCreatedBy")
  sessions         UserSession[]
  updatedCampaigns Campaign[]           @relation("CampaignUpdatedBy")
}

model UserSession {
  id               String    @id
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  replacedById     String?
  ipAddress        String?
  userAgent        String?
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SenderAccount {
  id                   String               @id @default(cuid())
  type                 SenderType
  label                String
  email                String
  provider             String
  status               SenderAccountStatus  @default(ACTIVE)
  healthStatus         SenderHealthStatus   @default(ACTIVE)
  lastHealthCheckAt    DateTime?
  lastHealthMessage    String?
  dailyLimit           Int
  encryptionKeyHint    String?
  credentialsEncrypted String?
  metadata             Json?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  recipientEvents      CampaignRecipient[]

  @@unique([type, email])
}

model SenderPolicy {
  id         String     @id @default(cuid())
  senderType SenderType @unique
  dailyLimit Int
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model UserSenderAllocation {
  id            String     @id @default(cuid())
  userId        String
  senderType    SenderType
  assignedLimit Int
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, senderType])
}

model Campaign {
  id              String              @id @default(cuid())
  senderType      SenderType
  userId          String
  fromName        String
  fromEmail       String?
  replyTo         String
  subject         String
  previewText     String?
  cc              String[]
  bcc             String[]
  contentHtml     String
  attachments     Json?
  status          CampaignStatus      @default(QUEUED)
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  completedAt     DateTime?
  createdBy       User                @relation("CampaignCreatedBy", fields: [userId], references: [id], onDelete: Cascade)
  updatedBy       User?               @relation("CampaignUpdatedBy", fields: [updatedById], references: [id])
  updatedById     String?
  recipientEvents CampaignRecipient[]
}

model CampaignRecipient {
  id                 String           @id @default(cuid())
  campaignId         String
  senderAccountId    String?
  recipientEmail     String
  status             RecipientStatus  @default(QUEUED)
  providerMessageId  String?
  messageIdHeader    String?
  smtpEnvelope       Json?
  emailHeaders       Json?
  errorMessage       String?
  sentAt             DateTime?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  campaign           Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  senderAccount      SenderAccount?   @relation(fields: [senderAccountId], references: [id], onDelete: SetNull)
}
